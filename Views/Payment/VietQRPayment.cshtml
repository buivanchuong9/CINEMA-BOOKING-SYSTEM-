@using BE.Core.Entities.Bookings
@using BE.Core.Entities.Movies
@using BE.Core.Entities.CinemaInfrastructure
@{
    ViewData["Title"] = "Thanh Toán VietQR - CineMax";
    Layout = "_Layout";
    var booking = ViewBag.Booking as Booking;
    var showtime = ViewBag.Showtime as Showtime;
    var movie = ViewBag.Movie as Movie;
    var room = ViewBag.Room as Room;
    
    // Hold seat time: 10 minutes from booking date
    var expiryTime = booking?.BookingDate.AddMinutes(10) ?? DateTime.Now;
    var secondsLeft = (expiryTime - DateTime.Now).TotalSeconds;
    if (secondsLeft < 0) secondsLeft = 0;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-11">
            <div class="payment-card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- TOP HEADER -->
                <div class="payment-header text-center py-4 px-3">
                    <h3 class="fw-bold mb-1 text-white text-uppercase tracking-wider">Thanh Toán VietQR</h3>
                    <p class="text-white-50 mb-0">Quét mã VietQR để hoàn tất đặt vé xem phim tại CineMax</p>
                </div>

                <div class="row g-0">
                    <!-- LEFT COLUMN: BOOKING DETAIL -->
                    <div class="col-lg-5 col-md-12 p-4 p-md-5 booking-info-column border-end border-dark">
                        <h5 class="section-title text-popcorn-gold fw-bold mb-4">
                            <i class="bi bi-film me-2"></i>Chi Tiết Đơn Hàng
                        </h5>

                        <div class="d-flex align-items-center mb-4">
                            <img src="@(movie?.PosterUrl ?? "/images/placeholder.jpg")" alt="@movie?.Title" class="poster-img rounded shadow-sm">
                            <div class="ms-4">
                                <h4 class="movie-title mb-1 text-white fw-bold">@movie?.Title</h4>
                                <span class="badge bg-danger rounded-pill px-3 py-1 text-xs mb-2">@movie?.AgeRating</span>
                                <p class="mb-0 text-muted small"><i class="bi bi-clock me-1"></i> @movie?.Duration phút</p>
                            </div>
                        </div>

                        <hr class="border-secondary my-4">

                        <div class="booking-details-grid">
                            <div class="row g-3">
                                <div class="col-6">
                                    <span class="detail-label d-block text-muted text-uppercase tracking-wider">Rạp chiếu</span>
                                    <span class="detail-value d-block text-white fw-bold mt-1">@room?.Cinema?.Name</span>
                                </div>
                                <div class="col-6">
                                    <span class="detail-label d-block text-muted text-uppercase tracking-wider">Phòng</span>
                                    <span class="detail-value d-block text-white fw-bold mt-1">@room?.Name</span>
                                </div>
                                <div class="col-6">
                                    <span class="detail-label d-block text-muted text-uppercase tracking-wider">Ngày chiếu</span>
                                    <span class="detail-value d-block text-white fw-bold mt-1">@showtime?.StartTime.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="col-6">
                                    <span class="detail-label d-block text-muted text-uppercase tracking-wider">Suất chiếu</span>
                                    <span class="detail-value d-block text-white fw-bold mt-1">@showtime?.StartTime.ToString("HH:mm")</span>
                                </div>
                            </div>
                        </div>

                        <hr class="border-secondary my-4">

                        <!-- Reservation Timer -->
                        <div class="timer-box p-3 rounded-3 text-center mb-4 border border-warning-subtle">
                            <span class="text-warning-emphasis d-block mb-1 small text-uppercase tracking-wider">Thời gian giữ ghế còn lại</span>
                            <div class="d-flex justify-content-center align-items-center gap-1">
                                <i class="bi bi-hourglass-split text-warning fs-4 me-1"></i>
                                <span id="countdown" class="fs-3 fw-bold text-warning font-monospace">00:00</span>
                            </div>
                        </div>

                        <div class="price-box p-3 rounded-3 d-flex justify-content-between align-items-center mt-auto">
                            <span class="fs-5 fw-bold text-white">Tổng thanh toán:</span>
                            <span class="fs-3 fw-extrabold text-cinema-red">@(booking?.TotalAmount.ToString("N0") ?? "0") ₫</span>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: QR CODE AND BANK DETAILS -->
                    <div class="col-lg-7 col-md-12 p-4 p-md-5 qr-payment-column">
                        <div class="row g-4 align-items-center">
                            <!-- QR CODE COLUMN -->
                            <div class="col-sm-6 text-center">
                                <div class="qr-container-outer mx-auto">
                                    <div class="qr-pulse-frame"></div>
                                    <div class="qr-image-wrapper p-3 bg-white rounded-3 shadow">
                                        <img src="@ViewBag.QRImageUrl" alt="VietQR Code" class="img-fluid qr-image">
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <span class="badge bg-secondary rounded-pill px-3 py-1">
                                        <i class="bi bi-qr-code-scan me-1"></i> Quét để thanh toán
                                    </span>
                                </div>
                            </div>

                            <!-- BANK INFORMATION COLUMN -->
                            <div class="col-sm-6">
                                <h5 class="section-title text-popcorn-gold fw-bold mb-3">Thông Tin Chuyển Khoản</h5>
                                
                                <div class="bank-info-list d-flex flex-column gap-3">
                                    <div class="info-card p-2 rounded border border-secondary bg-black-50">
                                        <label class="text-muted small text-uppercase">Ngân hàng</label>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="text-white fw-bold">@ViewBag.BankName</span>
                                        </div>
                                    </div>

                                    <div class="info-card p-2 rounded border border-secondary bg-black-50">
                                        <label class="text-muted small text-uppercase">Số tài khoản</label>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="text-white fw-bold font-monospace fs-5">@ViewBag.AccountNo</span>
                                            <button type="button" class="btn btn-sm btn-outline-light py-1 px-2" id="copyAccBtn" onclick="copyToClipboard('@ViewBag.AccountNo', 'copyAccBtn')">
                                                <i class="bi bi-clipboard"></i> Sao chép
                                            </button>
                                        </div>
                                    </div>

                                    <div class="info-card p-2 rounded border border-secondary bg-black-50">
                                        <label class="text-muted small text-uppercase">Chủ tài khoản</label>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="text-white fw-bold text-uppercase">@ViewBag.AccountName</span>
                                        </div>
                                    </div>

                                    <div class="info-card p-2 rounded border border-secondary bg-black-50">
                                        <label class="text-muted small text-uppercase">Số tiền</label>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="text-cinema-red fw-bold font-monospace fs-5">@(booking?.TotalAmount.ToString("N0") ?? "0") ₫</span>
                                        </div>
                                    </div>

                                    <div class="info-card p-2 rounded border border-secondary bg-black-50 border-warning-subtle">
                                        <label class="text-warning small text-uppercase">Nội dung chuyển khoản</label>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="text-warning fw-bold font-monospace fs-5">@ViewBag.TransferContent</span>
                                            <button type="button" class="btn btn-sm btn-outline-warning py-1 px-2" id="copyContentBtn" onclick="copyToClipboard('@ViewBag.TransferContent', 'copyContentBtn')">
                                                <i class="bi bi-clipboard"></i> Sao chép
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="border-secondary my-4">

                        <!-- CHECK PAYMENT STATUS BAR -->
                        <div id="payment-status-container" class="payment-status-box p-4 rounded-3 text-center border border-secondary bg-black-25">
                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <div class="spinner-border text-cinema-red" role="status" style="width: 1.5rem; height: 1.5rem;">
                                    <span class="visually-hidden">Checking...</span>
                                </div>
                                <div class="text-start">
                                    <span class="text-white fw-bold d-block">Đang chờ nhận tiền...</span>
                                    <span class="text-muted small">Hệ thống sẽ tự động xác nhận sau khi bạn chuyển khoản thành công.</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-sm-row flex-column gap-2 mt-4">
                                                            <button type="button" onclick="checkStatusManually()" class="btn btn-cinema-red rounded-pill py-2 px-4 fw-bold flex-fill">
                                                                <i class="bi bi-arrow-clockwise me-1"></i> Tôi Đã Thanh Toán (Kiểm tra lại)
                                                            </button>
                                                            <a href="@Url.Action("Cancel", "Booking", new { id = booking?.Id })" class="btn btn-outline-light rounded-pill py-2 px-4" onclick="return confirm('Bạn có chắc muốn hủy đơn hàng này?')">
                                                                <i class="bi bi-x-circle me-1"></i> Hủy Giao Dịch
                                                            </a>
                                                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hold seat timer logic
        var secondsLeft = @secondsLeft;
        var countdownElement = document.getElementById('countdown');

        function updateCountdown() {
            if (secondsLeft <= 0) {
                clearInterval(timerInterval);
                countdownElement.innerHTML = "00:00";
                countdownElement.classList.remove('text-warning');
                countdownElement.classList.add('text-danger');
                alert("Đơn hàng của bạn đã hết thời gian giữ ghế. Vui lòng đặt vé lại!");
                window.location.href = '@Url.Action("Index", "Movies")';
                return;
            }

            var minutes = Math.floor(secondsLeft / 60);
            var seconds = Math.floor(secondsLeft % 60);

            // Pad with zero
            minutes = minutes < 10 ? '0' + minutes : minutes;
            seconds = seconds < 10 ? '0' + seconds : seconds;

            countdownElement.innerHTML = minutes + ":" + seconds;
            secondsLeft--;
        }

        updateCountdown();
        var timerInterval = setInterval(updateCountdown, 1000);

        // Copy to clipboard helper
        function copyToClipboard(text, buttonId) {
            navigator.clipboard.writeText(text).then(function() {
                var btn = document.getElementById(buttonId);
                var originalContent = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Đã chép';
                btn.classList.remove('btn-outline-light', 'btn-outline-warning');
                btn.classList.add('btn-success', 'text-white');
                setTimeout(function() {
                    btn.innerHTML = originalContent;
                    btn.classList.remove('btn-success', 'text-white');
                    if (buttonId === 'copyContentBtn') {
                        btn.classList.add('btn-outline-warning');
                    } else {
                        btn.classList.add('btn-outline-light');
                    }
                }, 2000);
            }).catch(function(err) {
                console.error('Could not copy text: ', err);
            });
        }

        // Automatic Status Check via Polling
        var bookingId = @(booking?.Id ?? 0);
        var checkInterval = setInterval(function() {
            checkPaymentStatus();
        }, 3000); // Check every 3 seconds

        function checkPaymentStatus() {
            fetch('/Payment/CheckPaymentStatus?bookingId=' + bookingId)
                .then(response => response.json())
                .then(data => {
                    if (data.paid) {
                        clearInterval(checkInterval);
                        clearInterval(timerInterval);
                        
                        // Show successful UI
                        document.getElementById('payment-status-container').innerHTML = `
                            <div class="text-center py-2 text-success animate__animated animate__fadeIn">
                                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                                    <i class="bi bi-check-circle-fill fs-3"></i>
                                    <h5 class="fw-bold mb-0">Thanh toán thành công!</h5>
                                </div>
                                <p class="text-muted small mb-0">CineMax đã nhận được tiền. Đang khởi tạo hóa đơn...</p>
                            </div>
                        `;
                        
                        setTimeout(function() {
                            window.location.href = '/Booking/Details/' + bookingId;
                        }, 2000);
                    } else if (data.status === "Cancelled") {
                        clearInterval(checkInterval);
                        clearInterval(timerInterval);
                        alert("Đơn đặt vé này đã bị hủy!");
                        window.location.href = '/Movies/Index';
                    }
                })
                .catch(err => console.error("Error checking payment status: ", err));
        }

        function checkStatusManually() {
            // Immediately check once
            var statusBox = document.getElementById('payment-status-container');
            var originalContent = statusBox.innerHTML;
            
            statusBox.innerHTML = `
                <div class="d-flex align-items-center justify-content-center gap-3 py-1">
                    <div class="spinner-border text-cinema-red" role="status" style="width: 1.2rem; height: 1.2rem;">
                        <span class="visually-hidden">Checking...</span>
                    </div>
                    <span>Đang xác minh giao dịch trên hệ thống...</span>
                </div>
            `;
            
            fetch('/Payment/CheckPaymentStatus?bookingId=' + bookingId)
                .then(response => response.json())
                .then(data => {
                    if (data.paid) {
                        clearInterval(checkInterval);
                        clearInterval(timerInterval);
                        statusBox.innerHTML = `
                            <div class="text-center py-2 text-success">
                                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                                    <i class="bi bi-check-circle-fill fs-3"></i>
                                    <h5 class="fw-bold mb-0">Thanh toán thành công!</h5>
                                </div>
                                <p class="text-muted small mb-0">Đang khởi tạo hóa đơn...</p>
                            </div>
                        `;
                        setTimeout(function() {
                            window.location.href = '/Booking/Details/' + bookingId;
                        }, 1500);
                    } else {
                        // Restore original status message with slight message
                        setTimeout(function() {
                            statusBox.innerHTML = originalContent;
                            alert("Hệ thống chưa ghi nhận biến động số dư cho nội dung '" + '@ViewBag.TransferContent' + "'. Vui lòng đợi hoặc thử quét lại!");
                        }, 1000);
                    }
                })
                .catch(err => {
                    statusBox.innerHTML = originalContent;
                    console.error(err);
                });
        }
    </script>
}

<style>
    /* Premium aesthetics for VietQR Payment Screen */
    .payment-card {
        background: linear-gradient(145deg, #181c26 0%, #0e1118 100%);
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
    }
    
    .payment-header {
        background: linear-gradient(90deg, #e11d48 0%, #be123c 100%);
        box-shadow: 0 4px 15px rgba(225, 29, 72, 0.2);
    }
    
    .tracking-wider {
        letter-spacing: 0.1em;
    }
    
    .section-title {
        border-bottom: 2px solid #e11d48;
        padding-bottom: 8px;
        display: inline-block;
    }
    
    .poster-img {
        width: 90px;
        height: 130px;
        object-fit: cover;
        border: 2px solid rgba(255, 255, 255, 0.1);
    }
    
    .movie-title {
        font-size: 1.4rem;
        line-height: 1.2;
    }
    
    .detail-label {
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .detail-value {
        font-size: 1rem;
    }
    
    .timer-box {
        background: rgba(245, 158, 11, 0.08);
        border: 1px dashed rgba(245, 158, 11, 0.3) !important;
    }
    
    .price-box {
        background: rgba(225, 29, 72, 0.1);
        border: 1px solid rgba(225, 29, 72, 0.2);
    }
    
    .fw-extrabold {
        font-weight: 800;
    }
    
    /* QR code glowing styles */
    .qr-container-outer {
        position: relative;
        width: 220px;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .qr-image-wrapper {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .qr-image {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }
    
    .qr-pulse-frame {
        position: absolute;
        top: -8px;
        left: -8px;
        right: -8px;
        bottom: -8px;
        border: 2px solid #e11d48;
        border-radius: 12px;
        animation: qrPulse 2s infinite ease-in-out;
        z-index: 1;
        opacity: 0.7;
    }
    
    @@keyframes qrPulse {
        0% {
            transform: scale(0.97);
            box-shadow: 0 0 0 0 rgba(225, 29, 72, 0.5);
            opacity: 0.5;
        }
        50% {
            transform: scale(1.02);
            box-shadow: 0 0 20px 5px rgba(225, 29, 72, 0.3);
            opacity: 1;
        }
        100% {
            transform: scale(0.97);
            box-shadow: 0 0 0 0 rgba(225, 29, 72, 0.5);
            opacity: 0.5;
        }
    }
    
    .info-card {
        background-color: rgba(0, 0, 0, 0.3);
    }
    
    .bg-black-50 {
        background-color: rgba(0, 0, 0, 0.5) !important;
    }
    
    .bg-black-25 {
        background-color: rgba(0, 0, 0, 0.25) !important;
    }
</style>
