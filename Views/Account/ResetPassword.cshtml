@model BE.Application.DTOs.ResetPasswordDto
@{
    ViewData["Title"] = "Đặt lại mật khẩu - CineMax";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-panel left-panel">
        <div class="content-container fade-in-left">
            <div class="auth-header mb-5">
                <a href="/" class="brand-link text-decoration-none">
                    <i class="bi bi-film me-2 text-cinema-red"></i>
                    <span class="fw-bold text-white tracking-wider fs-4">CINEMAX</span>
                </a>
            </div>

            <div class="mb-5">
                <h1 class="fw-bold text-white mb-2 fs-2">Đặt Lại Mật Khẩu</h1>
                <p class="text-secondary">Vui lòng nhập mật khẩu mới cho tài khoản của bạn.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-custom mb-4 shake-animation">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @Html.ValidationSummary(false, "", new { @class = "mb-0 d-inline" })
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="ResetPassword">
                @Html.AntiForgeryToken()
                <input asp-for="Token" type="hidden" />
                <input asp-for="Email" type="hidden" />
                
                <div class="mb-4">
                    <label asp-for="NewPassword" class="form-label text-secondary small fw-bold">MẬT KHẨU MỚI</label>
                    <div class="position-relative">
                        <input asp-for="NewPassword" type="password" class="form-control custom-input" placeholder="Nhập mật khẩu mới" />
                        <i class="bi bi-key position-absolute top-50 end-0 translate-middle-y me-3 text-secondary"></i>
                    </div>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small mb-3 d-block"></span>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-secondary small fw-bold">XÁC NHẬN MẬT KHẨU</label>
                    <div class="position-relative">
                        <input asp-for="ConfirmPassword" type="password" class="form-control custom-input" placeholder="Xác nhận mật khẩu mới" />
                        <i class="bi bi-check-all position-absolute top-50 end-0 translate-middle-y me-3 text-secondary"></i>
                    </div>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small mb-3 d-block"></span>

                <button type="submit" class="btn btn-cinema-primary w-100 py-3 mb-4 fw-bold">
                    ĐẶT LẠI MẬT KHẨU <i class="bi bi-arrow-right-circle ms-2"></i>
                </button>
            </form>
        </div>
    </div>

    <div class="auth-panel right-panel">
        <div class="overlay"></div>
        <div class="visual-content text-center fade-in-up">
            <h2 class="display-6 fw-bold text-white mb-3">Bảo Mật Là Ưu Tiên</h2>
            <p class="text-white-50 fs-5">Sử dụng mật khẩu mạnh để bảo vệ thông tin cá nhân và lịch sử đặt vé của bạn.</p>
        </div>
    </div>
</div>

<style>
    body { background-color: #000000; font-family: 'Inter', sans-serif; color: #ffffff; }
    .auth-wrapper { display: flex; min-height: 100vh; }
    .left-panel { width: 500px; background-color: #141414; display: flex; align-items: center; justify-content: center; }
    .content-container { width: 100%; max-width: 400px; padding: 2rem; }
    .custom-input { background-color: #333333; border: 1px solid transparent; color: #ffffff !important; border-radius: 8px; height: 50px; }
    .custom-input:focus { background-color: #404040; border-color: #e50914; box-shadow: 0 0 0 4px rgba(229, 9, 20, 0.2); }
    .btn-cinema-primary { background: linear-gradient(45deg, #e50914, #b20710); color: white; border: none; text-transform: uppercase; }
    .btn-cinema-primary:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(229, 9, 20, 0.4); color: white; }
    .alert-custom { background: rgba(229, 9, 20, 0.1); border: 1px solid #e50914; color: #ff4d4d; font-size: 0.9rem; }
    .text-cinema-red { color: #e50914 !important; }
    .right-panel { flex: 1; background-image: url('https://images.unsplash.com/photo-1517604931442-7e0c8ed0963c?q=80&w=2670&auto=format&fit=crop'); background-size: cover; position: relative; display: flex; align-items: center; justify-content: center; }
    .right-panel .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(0,0,0,0.8), rgba(229, 9, 20, 0.4)); }
    .visual-content { position: relative; z-index: 3; max-width: 500px; }
    @@media (max-width: 992px) { .right-panel { display: none; } .left-panel { width: 100%; } }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
