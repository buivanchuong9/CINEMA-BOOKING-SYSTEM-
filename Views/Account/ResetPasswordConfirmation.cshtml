@{
    ViewData["Title"] = "Đặt lại mật khẩu thành công - CineMax";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-panel left-panel">
        <div class="content-container fade-in-left text-center">
            <div class="auth-header mb-5 text-start">
                <a href="/" class="brand-link text-decoration-none">
                    <i class="bi bi-film me-2 text-cinema-red"></i>
                    <span class="fw-bold text-white tracking-wider fs-4">CINEMAX</span>
                </a>
            </div>

            <div class="mb-5">
                <div class="success-icon mb-4">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h1 class="fw-bold text-white mb-2 fs-2">Thành Công!</h1>
                <p class="text-secondary">Mật khẩu của bạn đã được thay đổi thành công. Bây giờ bạn có thể đăng nhập bằng mật khẩu mới.</p>
            </div>

            <a href="/Account/Login" class="btn btn-cinema-primary w-100 py-3 mb-4 fw-bold">
                ĐĂNG NHẬP NGAY <i class="bi bi-box-arrow-in-right ms-2"></i>
            </a>
        </div>
    </div>

    <div class="auth-panel right-panel">
        <div class="overlay"></div>
        <div class="visual-content text-center fade-in-up">
            <h2 class="display-6 fw-bold text-white mb-3">Tài Khoản Đã Sẵn Sàng</h2>
            <p class="text-white-50 fs-5">Hãy đăng nhập và tiếp tục hành trình điện ảnh của bạn tại CineMax.</p>
        </div>
    </div>
</div>

<style>
    body { background-color: #000000; font-family: 'Inter', sans-serif; color: #ffffff; }
    .auth-wrapper { display: flex; min-height: 100vh; }
    .left-panel { width: 500px; background-color: #141414; display: flex; align-items: center; justify-content: center; }
    .content-container { width: 100%; max-width: 400px; padding: 2rem; }
    .success-icon { font-size: 5rem; color: #198754; }
    .btn-cinema-primary { background: linear-gradient(45deg, #e50914, #b20710); color: white; border: none; text-transform: uppercase; }
    .btn-cinema-primary:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(229, 9, 20, 0.4); color: white; }
    .text-cinema-red { color: #e50914 !important; }
    .right-panel { flex: 1; background-image: url('https://images.unsplash.com/photo-1440404653325-ab127d49abc1?q=80&w=2670&auto=format&fit=crop'); background-size: cover; position: relative; display: flex; align-items: center; justify-content: center; }
    .right-panel .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(0,0,0,0.8), rgba(229, 9, 20, 0.4)); }
    .visual-content { position: relative; z-index: 3; max-width: 500px; }
    @@media (max-width: 992px) { .right-panel { display: none; } .left-panel { width: 100%; } }
</style>
