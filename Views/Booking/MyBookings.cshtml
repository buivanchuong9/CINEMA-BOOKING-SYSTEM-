@using BE.Application.Helpers
@model PaginatedList<BE.Core.Entities.Bookings.Booking>
@{
    ViewData["Title"] = "Vé Của Tôi - CineMax";
}

<!-- My Bookings Page -->
<section class="py-5">
    <div class="container">
        <!-- Header -->
        <div class="mb-4" data-aos="fade-up">
            <h2 class="fw-bold mb-1">
                <i class="bi bi-ticket-perforated me-2 text-cinema-red"></i>
                Vé Của Tôi
            </h2>
            <p class="text-muted mb-0">Trang @Model.PageIndex / @Model.TotalPages</p>
        </div>

        @if (!Model.Any())
        {
            <!-- Empty State -->
            <div class="text-center py-5" data-aos="fade-up">
                <i class="bi bi-ticket-perforated display-1 text-muted mb-3"></i>
                <h4 class="text-muted">Chưa có vé nào</h4>
                <p class="text-muted mb-4">Bạn chưa đặt vé nào. Hãy chọn phim yêu thích và đặt vé ngay!</p>
                <a href="/Movies" class="btn btn-cinema-red">
                    <i class="bi bi-film me-2"></i>
                    Xem Phim
                </a>
            </div>
        }
        else
        {
            <!-- Bookings List -->
            <div class="row g-4">
                @foreach (var booking in Model)
                {
                    <div class="col-12" data-aos="fade-up">
                        <div class="booking-card glass-card p-4">
                            <div class="row align-items-center">
                                <!-- Booking Info -->
                                <div class="col-md-8">
                                    <div class="d-flex align-items-start mb-3">
                                        <div class="booking-id-badge me-3">
                                            #@booking.Id.ToString("D6")
                                        </div>
                                        <div class="flex-grow-1">
                                            <h5 class="mb-2">
                                                @{
                                                    var statusClass = booking.Status switch
                                                    {
                                                        BE.Core.Enums.BookingStatus.Paid => "success",
                                                        BE.Core.Enums.BookingStatus.Pending => "warning",
                                                        BE.Core.Enums.BookingStatus.Cancelled => "danger",
                                                        _ => "secondary"
                                                    };
                                                    var statusText = booking.Status switch
                                                    {
                                                        BE.Core.Enums.BookingStatus.Paid => "Đã thanh toán",
                                                        BE.Core.Enums.BookingStatus.Pending => "Chờ thanh toán",
                                                        BE.Core.Enums.BookingStatus.Cancelled => "Đã hủy",
                                                        _ => "Không xác định"
                                                    };
                                                }
                                                <span class="badge bg-@statusClass">@statusText</span>
                                            </h5>
                                            <div class="booking-meta">
                                                <div class="mb-2">
                                                    <i class="bi bi-calendar3 text-cinema-red me-2"></i>
                                                    <strong>Ngày đặt:</strong> @booking.BookingDate.ToString("dd/MM/yyyy HH:mm")
                                                </div>
                                                @if (!string.IsNullOrEmpty(booking.TransactionId))
                                                {
                                                    <div class="mb-2">
                                                        <i class="bi bi-credit-card text-popcorn-gold me-2"></i>
                                                        <strong>Mã GD:</strong> @booking.TransactionId
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(booking.Notes))
                                                {
                                                    <div>
                                                        <i class="bi bi-chat-left-text text-muted me-2"></i>
                                                        <strong>Ghi chú:</strong> @booking.Notes
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                 <!-- Price & Actions -->
                                <div class="col-md-4 text-md-end">
                                    <div class="mb-3">
                                        <small class="text-muted d-block">Tổng tiền</small>
                                        <h3 class="text-cinema-red mb-0">
                                            @booking.TotalAmount.ToString("N0") ₫
                                        </h3>
                                    </div>

                                    @{
                                        var expiryTime = booking.BookingDate.AddMinutes(10);
                                        var secondsRemaining = (expiryTime - DateTime.Now).TotalSeconds;
                                        bool stillPending = booking.Status == BE.Core.Enums.BookingStatus.Pending && secondsRemaining > 0;
                                        bool expiredPending = booking.Status == BE.Core.Enums.BookingStatus.Pending && secondsRemaining <= 0;
                                    }

                                    @if (stillPending)
                                    {
                                        <div class="pending-timer-badge mb-3 text-center py-2 px-3 rounded-3">
                                            <small class="text-muted d-block mb-1" style="font-size:0.72rem; letter-spacing:0.05em; text-transform:uppercase;">Giữ ghế còn</small>
                                            <span class="text-warning fw-bold font-monospace pending-countdown"
                                                  data-seconds="@((int)secondsRemaining)">
                                                @{
                                                    int m = (int)secondsRemaining / 60;
                                                    int s = (int)secondsRemaining % 60;
                                                }
                                                @m.ToString("D2"):@s.ToString("D2")
                                            </span>
                                        </div>
                                    }

                                    <div class="d-grid gap-2">
                                        @if (booking.Status == BE.Core.Enums.BookingStatus.Paid)
                                        {
                                            <a href="/Booking/Details/@booking.Id" class="btn btn-outline-light btn-sm">
                                                <i class="bi bi-eye me-1"></i>Xem hóa đơn
                                            </a>
                                            @if (booking.RefundStatus == "None")
                                            {
                                                <a href="/Booking/CancelTicket/@booking.Id"
                                                   class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-x-circle me-1"></i>Hủy vé & hoàn tiền
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="/Booking/CancelledTickets"
                                                   class="btn btn-outline-warning btn-sm">
                                                    <i class="bi bi-hourglass-split me-1"></i>Xem trạng thái hoàn tiền
                                                </a>
                                            }
                                        }
                                        else if (stillPending)
                                        {
                                            <a href="/Payment/VietQRPayment?bookingId=@booking.Id"
                                               class="btn btn-success btn-sm fw-bold">
                                                <i class="bi bi-qr-code-scan me-1"></i>Tiếp tục thanh toán
                                            </a>
                                            <a href="/Booking/CancelPayment?id=@booking.Id"
                                               class="btn btn-outline-warning btn-sm">
                                                <i class="bi bi-x-circle me-1"></i>Hủy giao dịch
                                            </a>
                                        }
                                        else if (expiredPending)
                                        {
                                            <span class="badge bg-secondary py-2 px-3 mb-1">
                                                <i class="bi bi-clock-history me-1"></i>Hết thời gian giữ ghế
                                            </span>
                                            <a href="/Booking/CancelPayment?id=@booking.Id"
                                               class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash me-1"></i>Xóa đơn hủy
                                            </a>
                                        }
                                        else
                                        {
                                            <!-- Cancelled -->
                                            <span class="badge bg-secondary py-2 px-3">
                                                <i class="bi bi-slash-circle me-1"></i>Đã hủy
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            <div class="d-flex justify-content-center mt-5">
                <nav>
                    <ul class="pagination">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" href="/Booking/MyBookings?pageNumber=@(Model.PageIndex - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link @(i == Model.PageIndex ? "bg-cinema-red border-cinema-red" : "bg-dark border-secondary text-white")" 
                                   href="/Booking/MyBookings?pageNumber=@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" href="/Booking/MyBookings?pageNumber=@(Model.PageIndex + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        // Live countdown for Pending bookings
        document.querySelectorAll('.pending-countdown').forEach(function(el) {
            var secs = parseInt(el.dataset.seconds, 10);
            if (isNaN(secs) || secs <= 0) return;

            var interval = setInterval(function() {
                secs--;
                if (secs <= 0) {
                    clearInterval(interval);
                    el.textContent = '00:00';
                    el.classList.replace('text-warning', 'text-danger');
                    // Show a small expired indicator
                    var badge = el.closest('.pending-timer-badge');
                    if (badge) {
                        badge.innerHTML = '<small class="text-danger"><i class="bi bi-clock-history me-1"></i>Đã hết thời gian giữ ghế</small>';
                    }
                    return;
                }
                var m = Math.floor(secs / 60);
                var s = secs % 60;
                el.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
            }, 1000);
        });

        function confirmCancel(bookingId) {
            Swal.fire({
                title: 'Xác nhận hủy vé?',
                text: 'Bạn có chắc chắn muốn hủy vé này? Hành động này không thể hoàn tác!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Hủy vé',
                cancelButtonText: 'Không',
                background: '#1e293b',
                color: '#f8fafc'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = `/Booking/Cancel/${bookingId}`;
                    const csrf = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (csrf) form.appendChild(csrf.cloneNode(true));
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}

<style>
    .booking-card {
        border-radius: 16px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .booking-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(220, 38, 38, 0.2);
    }
    
    .booking-id-badge {
        background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
        padding: 10px 15px;
        border-radius: 8px;
        font-weight: bold;
        font-size: 18px;
        min-width: 100px;
        text-align: center;
    }
    
    .booking-meta {
        font-size: 14px;
    }
    
    .booking-meta i {
        width: 20px;
    }
    
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .pending-timer-badge {
        background: rgba(245, 158, 11, 0.08);
        border: 1px dashed rgba(245, 158, 11, 0.35);
    }
</style>

<!-- CSRF Token for cancel form -->
@Html.AntiForgeryToken()
