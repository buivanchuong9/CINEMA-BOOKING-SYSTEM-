@using BE.Core.Entities.Bookings
@using BE.Core.Entities.Movies
@{
    ViewData["Title"] = "Vé Đã Hủy - CineMax";
    Layout = "_Layout";
    var bookingInfos = ViewBag.BookingInfos as List<(Booking booking, Movie? movie, Showtime? showtime)> ?? new List<(Booking, Movie?, Showtime?)>();
}

<section class="py-5">
    <div class="container">

        @* ── HEADER ── *@
        <div class="mb-5" data-aos="fade-up">
            <div class="d-flex align-items-center gap-3 mb-2">
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-slash-circle me-2 text-cinema-red"></i>
                    Vé Đã Hủy
                </h2>
                @if (bookingInfos.Any(x => x.booking.RefundStatus == "Pending"))
                {
                    <span class="badge bg-warning text-dark fs-6">
                        <i class="bi bi-hourglass-split me-1"></i>
                        @bookingInfos.Count(x => x.booking.RefundStatus == "Pending") yêu cầu đang xử lý
                    </span>
                }
            </div>
            <p class="text-muted mb-0">Theo dõi trạng thái hoàn tiền cho các vé đã hủy của bạn.</p>
        </div>

        <div class="row g-3 mb-5" data-aos="fade-up">
            <div class="col-md-3">
                <div class="stat-mini-card text-center p-3 rounded-3">
                    <div class="stat-num text-white fw-bold fs-3">@bookingInfos.Count</div>
                    <div class="text-muted small">Tổng vé đã hủy</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-mini-card stat-pending text-center p-3 rounded-3">
                    <div class="stat-num text-warning fw-bold fs-3">@bookingInfos.Count(x => x.booking.RefundStatus == "Pending")</div>
                    <div class="text-muted small">Chờ hoàn tiền</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-mini-card stat-refunded text-center p-3 rounded-3">
                    <div class="stat-num text-success fw-bold fs-3">@bookingInfos.Count(x => x.booking.RefundStatus == "Refunded")</div>
                    <div class="text-muted small">Đã hoàn tiền</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-mini-card stat-none text-center p-3 rounded-3">
                    <div class="stat-num text-secondary fw-bold fs-3">@bookingInfos.Count(x => x.booking.RefundStatus == "None")</div>
                    <div class="text-muted small">Không hoàn tiền</div>
                </div>
            </div>
        </div>

        @if (!bookingInfos.Any())
        {
            <div class="text-center py-5" data-aos="fade-up">
                <i class="bi bi-check-circle display-1 text-success mb-3"></i>
                <h4 class="text-muted">Không có vé nào đã hủy</h4>
                <p class="text-muted mb-4">Bạn chưa hủy vé nào. Tiếp tục tận hưởng những bộ phim tuyệt vời!</p>
                <a href="/Movies" class="btn btn-cinema-red rounded-pill px-4">
                    <i class="bi bi-film me-2"></i>Xem Phim
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in bookingInfos)
                {
                    var booking = item.booking;
                    var movie   = item.movie;
                    var showtime = item.showtime;
                    var refundBadgeClass = booking.RefundStatus switch
                    {
                        "Pending"  => "warning",
                        "Refunded" => "success",
                        "Rejected" => "danger",
                        _          => "secondary"
                    };
                    var refundBadgeText = booking.RefundStatus switch
                    {
                        "Pending"  => "Chờ hoàn tiền",
                        "Refunded" => "Đã hoàn tiền",
                        "Rejected" => "Từ chối hoàn tiền",
                        _          => "Không yêu cầu hoàn tiền"
                    };
                    var refundBadgeIcon = booking.RefundStatus switch
                    {
                        "Pending"  => "bi-hourglass-split",
                        "Refunded" => "bi-check-circle-fill",
                        "Rejected" => "bi-x-circle-fill",
                        _          => "bi-slash-circle"
                    };
                    <div class="col-12" data-aos="fade-up">
                        <div class="cancelled-card p-4 rounded-4">
                            <div class="row align-items-start g-3">

                                @* Movie poster *@
                                <div class="col-auto d-none d-md-block">
                                    <img src="@(movie?.PosterUrl ?? "/images/placeholder.jpg")"
                                         alt="@movie?.Title"
                                         class="cancelled-poster rounded-2">
                                </div>

                                @* Main info *@
                                <div class="col">
                                    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-2">
                                        <div>
                                            <span class="booking-id-badge me-2">#@booking.Id.ToString("D6")</span>
                                            <span class="badge bg-@refundBadgeClass py-2 px-3">
                                                <i class="bi @refundBadgeIcon me-1"></i>@refundBadgeText
                                            </span>
                                        </div>
                                        <div class="text-end">
                                            <div class="text-muted small">Số tiền</div>
                                            <div class="fw-bold text-cinema-red fs-5">@booking.TotalAmount.ToString("N0") ₫</div>
                                        </div>
                                    </div>

                                    <h5 class="fw-bold text-white mb-1">@(movie?.Title ?? "Phim chưa xác định")</h5>
                                    @if (showtime != null)
                                    {
                                        <p class="text-muted small mb-2">
                                            <i class="bi bi-calendar3 me-1"></i>@showtime.StartTime.ToString("dd/MM/yyyy HH:mm")
                                        </p>
                                    }
                                    <p class="text-muted small mb-0">
                                        <i class="bi bi-clock-history me-1"></i>
                                        Ngày hủy: @((booking.UpdatedAt ?? booking.BookingDate).ToString("dd/MM/yyyy HH:mm"))
                                    </p>

                                    @* Refund bank info *@
                                    @if (booking.RefundStatus != "None" && !string.IsNullOrEmpty(booking.RefundAccountNumber))
                                    {
                                        <div class="bank-info-box mt-3 p-3 rounded-3">
                                            <div class="text-muted small mb-2 fw-semibold text-uppercase" style="letter-spacing:.05em;">
                                                <i class="bi bi-bank me-1"></i> Thông tin hoàn tiền
                                            </div>
                                            <div class="row g-2">
                                                <div class="col-sm-4">
                                                    <div class="text-muted" style="font-size:.78rem;">Ngân hàng</div>
                                                    <div class="text-white fw-semibold">@booking.RefundBankName</div>
                                                </div>
                                                <div class="col-sm-4">
                                                    <div class="text-muted" style="font-size:.78rem;">Số tài khoản</div>
                                                    <div class="text-white fw-bold font-monospace">@booking.RefundAccountNumber</div>
                                                </div>
                                                <div class="col-sm-4">
                                                    <div class="text-muted" style="font-size:.78rem;">Tên tài khoản</div>
                                                    <div class="text-white fw-semibold">@booking.RefundAccountName</div>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @* Refund proof image *@
                                    @if (booking.RefundStatus == "Refunded" && !string.IsNullOrEmpty(booking.RefundProofUrl))
                                    {
                                        <div class="mt-3">
                                            <div class="text-muted small mb-2 fw-semibold text-uppercase" style="letter-spacing:.05em;">
                                                <i class="bi bi-image me-1"></i> Bằng chứng chuyển khoản từ Admin
                                            </div>
                                            <a href="@booking.RefundProofUrl" target="_blank" class="proof-img-link">
                                                <img src="@booking.RefundProofUrl" alt="Bằng chứng hoàn tiền"
                                                     class="proof-img rounded-3">
                                                <div class="proof-overlay">
                                                    <i class="bi bi-zoom-in fs-4"></i>
                                                </div>
                                            </a>
                                            <p class="text-success small mt-2">
                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                Tiền đã được chuyển thành công!
                                            </p>
                                        </div>
                                    }

                                    @* Rejected message *@
                                    @if (booking.RefundStatus == "Rejected")
                                    {
                                        <div class="alert alert-danger mt-3 py-2 px-3 rounded-3 border-0 small">
                                            <i class="bi bi-x-circle-fill me-2"></i>
                                            Yêu cầu hoàn tiền đã bị từ chối. Vui lòng liên hệ Admin để biết thêm thông tin.
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a href="/Booking/MyBookings" class="btn btn-outline-light rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i>Quay Lại Vé Của Tôi
                </a>
            </div>
        }

    </div>
</section>

<style>
    .stat-mini-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
    }
    .stat-pending  { border-color: rgba(245,158,11,0.3)  !important; background: rgba(245,158,11,0.05)  !important; }
    .stat-refunded { border-color: rgba(34,197,94,0.3)   !important; background: rgba(34,197,94,0.05)   !important; }
    .stat-none     { border-color: rgba(107,114,128,0.3) !important; background: rgba(107,114,128,0.05) !important; }

    .cancelled-card {
        background: linear-gradient(145deg, #1a1e2e 0%, #111520 100%);
        border: 1px solid rgba(255,255,255,0.08);
        transition: box-shadow 0.3s;
    }
    .cancelled-card:hover {
        box-shadow: 0 8px 30px rgba(220,38,38,0.12);
    }
    .cancelled-poster {
        width: 70px;
        height: 100px;
        object-fit: cover;
    }
    .booking-id-badge {
        display: inline-block;
        background: linear-gradient(135deg, #dc2626, #991b1b);
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: bold;
        font-size: 0.85rem;
    }
    .bank-info-box {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .proof-img-link {
        position: relative;
        display: inline-block;
        cursor: pointer;
    }
    .proof-img {
        width: 160px;
        height: 100px;
        object-fit: cover;
        display: block;
        transition: filter 0.2s;
    }
    .proof-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.55);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        opacity: 0;
        transition: opacity 0.2s;
        border-radius: 8px;
    }
    .proof-img-link:hover .proof-overlay { opacity: 1; }
    .proof-img-link:hover .proof-img     { filter: brightness(0.7); }
</style>
