@model BE.Core.Entities.Movies.Movie
@{
    ViewData["Title"] = Model.Title + " - CineMax";
    var showtimes = ViewBag.Showtimes as List<BE.Core.Entities.Movies.Showtime> ?? new List<BE.Core.Entities.Movies.Showtime>();
}

<!-- Movie Details Hero -->
<section class="movie-hero" style="background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.9)), url('@(Model.PosterUrl ?? "/images/default-movie.jpg")');">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(Model.PosterUrl))
                {
                    <img src="@Model.PosterUrl" alt="@Model.Title" class="img-fluid rounded shadow-lg">
                }
                else
                {
                    <div class="poster-placeholder bg-dark rounded d-flex align-items-center justify-content-center" style="height: 500px;">
                        <i class="bi bi-film display-1 text-muted"></i>
                    </div>
                }
            </div>
            <div class="col-md-8">
                <div class="movie-info">
                    @if (!string.IsNullOrEmpty(Model.AgeRating))
                    {
                        <span class="badge bg-cinema-red mb-3">@Model.AgeRating</span>
                    }
                    
                    <h1 class="fw-bold display-4 mb-3">@Model.Title</h1>
                    
                    <div class="movie-meta mb-4">
                        @if (Model.Rating.HasValue)
                        {
                            <span class="me-4">
                                <i class="bi bi-star-fill text-warning"></i>
                                <strong>@Model.Rating.Value.ToString("0.0")</strong>/10
                            </span>
                        }
                        <span class="me-4">
                            <i class="bi bi-clock text-cinema-red"></i>
                            @Model.Duration phút
                        </span>
                        <span>
                            <i class="bi bi-calendar text-cinema-red"></i>
                            @Model.ReleaseDate.ToString("dd/MM/yyyy")
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="lead mb-4">@Model.Description</p>
                    }

                    <div class="movie-crew mb-4">
                        @if (!string.IsNullOrEmpty(Model.Director))
                        {
                            <p class="mb-2">
                                <strong>Đạo diễn:</strong> @Model.Director
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Cast))
                        {
                            <p class="mb-2">
                                <strong>Diễn viên:</strong> @Model.Cast
                            </p>
                        }
                    </div>

                    <div class="d-flex gap-3">
                        @if (Model.Status == BE.Core.Enums.MovieStatus.NowShowing)
                        {
                            @if (showtimes.Any())
                            {
                                <a href="#showtimesSection" class="btn btn-cinema-red btn-lg" onclick="scrollToShowtimes(); return false;">
                                    <i class="bi bi-ticket-perforated me-2"></i>
                                    Chọn Suất Chiếu
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-cinema-red btn-lg" disabled>
                                    <i class="bi bi-ticket-perforated me-2"></i>
                                    Chưa có lịch chiếu
                                </button>
                            }
                        }
                        @if (!string.IsNullOrEmpty(Model.TrailerUrl))
                        {
                            <button class="btn btn-outline-light btn-lg" data-bs-toggle="modal" data-bs-target="#trailerModal">
                                <i class="bi bi-play-circle me-2"></i>
                                Xem Trailer
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Showtimes Section -->
<section class="py-5 bg-dark-subtle" id="showtimesSection">
    <div class="container">
        <div class="d-flex align-items-center mb-4">
            <div class="showtime-header-icon me-3">
                <i class="bi bi-calendar-event"></i>
            </div>
            <h3 class="fw-bold mb-0">Lịch Chiếu</h3>
        </div>
        
        @if (showtimes.Any())
        {
            // Group by date
            var showtimesByDate = showtimes.GroupBy(st => st.StartTime.Date).OrderBy(g => g.Key);
            
            foreach (var dateGroup in showtimesByDate)
            {
                <div class="showtime-date-group mb-4">
                    <div class="date-header">
                        <i class="bi bi-calendar3 me-2"></i>
                        <span class="fw-semibold">@dateGroup.Key.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</span>
                    </div>
                    @{
                        // Group by cinema
                        var byCinema = dateGroup.GroupBy(st => st.Room?.Cinema?.Name ?? "Rạp không xác định");
                    }
                    @foreach (var cinemaGroup in byCinema)
                    {
                        <div class="cinema-group mb-4">
                            <div class="cinema-name mb-3">
                                <i class="bi bi-building me-2"></i>
                                <span>@cinemaGroup.Key</span>
                            </div>
                            <div class="row g-3">
                                @foreach (var showtime in cinemaGroup.OrderBy(st => st.StartTime))
                                {
                                    var isExpired = showtime.StartTime < DateTime.Now;
                                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 col-6">
                                        <a href="@(isExpired ? "javascript:void(0)" : "/Booking/SelectSeats?showtimeId=" + showtime.Id)" 
                                           class="showtime-card @(isExpired ? "expired" : "")">
                                            <div class="showtime-time">@showtime.StartTime.ToString("HH:mm")</div>
                                            <div class="showtime-room">@(showtime.Room?.Name ?? "N/A")</div>
                                            <div class="showtime-price">@showtime.BasePrice.ToString("N0") ₫</div>
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="alert alert-info d-flex align-items-center">
                <i class="bi bi-info-circle me-3 fs-4"></i>
                <div>
                    <strong>Chưa có lịch chiếu</strong>
                    <p class="mb-0 small">Vui lòng quay lại sau để xem lịch chiếu mới nhất!</p>
                </div>
            </div>
        }
</section>

<!-- Reviews Section -->
<section class="py-5" id="reviewsSection">
    <div class="container">
        <!-- Section Title -->
        <div class="d-flex align-items-center mb-4 text-white">
            <div class="showtime-header-icon me-3">
                <i class="bi bi-chat-left-heart"></i>
            </div>
            <h3 class="fw-bold mb-0">Đánh Giá & Nhận Xét</h3>
        </div>

        <div class="row g-4">
            <!-- Review Stats & Form -->
            <div class="col-lg-5">
                <!-- Summary Card -->
                <div class="review-summary-card mb-4 p-4 rounded text-center" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08);">
                    <h5 class="text-uppercase text-muted mb-2" style="font-size: 0.85rem; letter-spacing: 1px;">Điểm số phim</h5>
                    @if (Model.Rating.HasValue && Model.Rating.Value > 0)
                    {
                        <div class="display-3 fw-bold text-warning mb-1">@Model.Rating.Value.ToString("0.0")</div>
                        <div class="mb-2">
                            @{
                                double stars = (double)Model.Rating.Value / 2.0;
                                int fullStars = (int)Math.Floor(stars);
                                bool halfStar = (stars - fullStars) >= 0.25;
                            }
                            <span class="text-warning fs-5">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    if (s <= fullStars)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else if (s == fullStars + 1 && halfStar)
                                    {
                                        <i class="bi bi-star-half"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                }
                            </span>
                        </div>
                        <p class="text-secondary mb-0">Dựa trên @((ViewBag.Reviews as List<BE.Core.Entities.Movies.MovieReview>)?.Count ?? 0) lượt đánh giá</p>
                    }
                    else
                    {
                        <div class="display-4 fw-bold text-muted mb-2">- / 10</div>
                        <p class="text-secondary mb-0">Chưa có lượt đánh giá nào cho phim này</p>
                    }
                </div>

                <!-- Review Form -->
                <div class="glass-card p-4">
                    <h5 class="fw-bold mb-3 text-white">Viết đánh giá của bạn</h5>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (ViewBag.HasReviewed == true)
                        {
                            <div class="alert alert-success d-flex align-items-center mb-0">
                                <i class="bi bi-check-circle-fill me-3 fs-4 text-success"></i>
                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">Bạn đã đánh giá phim này</h6>
                                    <p class="mb-0 small text-secondary">Mỗi tài khoản chỉ được đánh giá một lần và không thể chỉnh sửa.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <form action="/Reviews/Create" method="post" id="reviewForm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="movieId" value="@Model.Id" />
                                <input type="hidden" name="rating" id="ratingInput" value="5" />
                                
                                <div class="mb-3">
                                    <label class="form-label d-block text-white">Chọn số sao của bạn:</label>
                                    <div class="star-rating-selector fs-3 text-warning d-flex gap-2">
                                        <i class="bi bi-star-fill rating-star" data-value="1" style="cursor: pointer;"></i>
                                        <i class="bi bi-star-fill rating-star" data-value="2" style="cursor: pointer;"></i>
                                        <i class="bi bi-star-fill rating-star" data-value="3" style="cursor: pointer;"></i>
                                        <i class="bi bi-star-fill rating-star" data-value="4" style="cursor: pointer;"></i>
                                        <i class="bi bi-star-fill rating-star" data-value="5" style="cursor: pointer;"></i>
                                    </div>
                                    <div class="small text-muted mt-1" id="starDescription">Tuyệt vời! (5/5)</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="commentArea" class="form-label text-white">Ý kiến của bạn:</label>
                                    <textarea class="form-control bg-dark text-white border-secondary" id="commentArea" name="comment" rows="4" required placeholder="Nhập cảm nhận của bạn về bộ phim..."></textarea>
                                </div>
                                
                                <button type="submit" class="btn btn-cinema-red w-100 rounded-pill py-2">
                                    <i class="bi bi-send-fill me-2"></i> Gửi Đánh Giá
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <i class="bi bi-lock display-6 text-muted mb-3"></i>
                            <p class="text-secondary mb-3">Vui lòng đăng nhập để gửi đánh giá cho bộ phim này.</p>
                            <a href="/Account/Login?returnUrl=@(Context.Request.Path + Context.Request.QueryString)" class="btn btn-outline-danger rounded-pill px-4">
                                <i class="bi bi-box-arrow-in-right me-2"></i> Đăng Nhập Ngay
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Reviews List -->
            <div class="col-lg-7">
                <div class="glass-card p-4 h-100" style="max-height: 600px; overflow-y: auto;">
                    <h5 class="fw-bold mb-4 text-white">Nhận xét từ người xem</h5>
                    
                    @{
                        var reviewsList = ViewBag.Reviews as List<BE.Core.Entities.Movies.MovieReview> ?? new List<BE.Core.Entities.Movies.MovieReview>();
                    }

                    @if (!reviewsList.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-chat-left-dots display-3 text-secondary mb-3"></i>
                            <p class="mb-0">Chưa có bình luận nào. Hãy là người đầu tiên chia sẻ cảm nghĩ!</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-4">
                            @foreach (var review in reviewsList)
                            {
                                <div class="review-item border-bottom border-secondary pb-3">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(review.User?.AvatarUrl))
                                            {
                                                <img src="@review.User.AvatarUrl" alt="@review.User.FullName" class="rounded-circle" style="width: 45px; height: 45px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold" style="width: 45px; height: 45px; font-size: 0.95rem;">
                                                    @(review.User?.FullName?.Substring(0, Math.Min(1, review.User.FullName.Length)).ToUpper() ?? "?")
                                                </div>
                                            }
                                            <div>
                                                <h6 class="fw-semibold mb-0 text-white">@review.User?.FullName</h6>
                                                <span class="text-warning small">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= review.Rating)
                                                        {
                                                            <i class="bi bi-star-fill me-1"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-star me-1"></i>
                                                        }
                                                    }
                                                </span>
                                            </div>
                                        </div>
                                        <small class="text-secondary"><i class="bi bi-clock me-1"></i>@review.CreatedAt.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <p class="text-secondary mb-2 ms-5" style="white-space: pre-line;">@review.Comment</p>

                                    @if (!string.IsNullOrEmpty(review.Response))
                                    {
                                        <div class="admin-response ms-5 p-3 rounded bg-dark border-start border-warning mt-2">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <span class="badge bg-warning text-dark"><i class="bi bi-shield-check me-1"></i>Phản hồi từ CineMax</span>
                                                <small class="text-secondary">@review.RespondedAt?.ToString("dd/MM/yyyy")</small>
                                            </div>
                                            <p class="mb-0 text-light small" style="white-space: pre-line;">@review.Response</p>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trailer Modal -->
@if (!string.IsNullOrEmpty(Model.TrailerUrl))
{
    <div class="modal fade" id="trailerModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Trailer - @Model.Title</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="ratio ratio-16x9">
                        <iframe src="@Model.TrailerUrl" allowfullscreen></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .movie-hero {
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 600px;
    }

    .movie-meta span {
        font-size: 1.1rem;
    }

    .movie-crew p {
        font-size: 0.95rem;
    }
    
    /* Showtimes Section Styling */
    #showtimesSection {
        background: linear-gradient(180deg, rgba(17, 24, 39, 0.5) 0%, rgba(17, 24, 39, 0.8) 100%);
    }
    
    .showtime-header-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
    }
    
    .showtime-date-group {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 16px;
        padding: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .date-header {
        color: #fbbf24;
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid rgba(251, 191, 36, 0.3);
    }
    
    .cinema-name {
        color: #9ca3af;
        font-size: 0.95rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .showtime-card {
        display: block;
        background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
        border: 1.5px solid rgba(100, 116, 139, 0.3);
        border-radius: 14px;
        padding: 1rem 0.75rem;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    
    .showtime-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(220, 38, 38, 0.1) 0%, rgba(153, 27, 27, 0.1) 100%);
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .showtime-card:hover {
        border-color: #dc2626;
        transform: translateY(-4px) scale(1.02);
        box-shadow: 0 8px 24px rgba(220, 38, 38, 0.4),
                    0 0 0 1px rgba(220, 38, 38, 0.2);
    }
    
    .showtime-card:hover::before {
        opacity: 1;
    }
    
    .showtime-card:active {
        transform: translateY(-2px) scale(1.01);
    }
    
    .showtime-card.expired {
        opacity: 0.5;
        cursor: not-allowed;
        filter: grayscale(1);
    }
    
    .showtime-card.expired:hover {
        transform: none;
        box-shadow: none;
        border-color: rgba(100, 116, 139, 0.3);
    }
    
    .showtime-time {
        font-size: 1.5rem;
        font-weight: 700;
        color: #dc2626;
        margin-bottom: 0.5rem;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 8px rgba(220, 38, 38, 0.3);
    }
    
    .showtime-room {
        font-size: 0.8rem;
        color: #9ca3af;
        margin-bottom: 0.4rem;
        position: relative;
        z-index: 1;
        font-weight: 500;
    }
    
    .showtime-price {
        font-size: 0.85rem;
        color: #10b981;
        font-weight: 600;
        position: relative;
        z-index: 1;
    }
    
    
    /* Reviews Styling */
    .star-rating-selector .rating-star {
        transition: transform 0.2s, color 0.2s;
    }
    .star-rating-selector .rating-star:hover {
        transform: scale(1.2);
    }
    .review-item {
        transition: background 0.3s;
    }
    .admin-response {
        background: rgba(251, 191, 36, 0.05) !important;
    }
    
    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .showtime-header-icon {
            width: 40px;
            height: 40px;
            font-size: 1.2rem;
        }
        
        .showtime-time {
            font-size: 1.3rem;
        }
        
        .showtime-card {
            padding: 0.75rem 0.5rem;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function scrollToShowtimes() {
        const element = document.getElementById('showtimesSection');
        if (element) {
            element.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        // Interactive Star Rating
        const stars = document.querySelectorAll('.rating-star');
        const ratingInput = document.getElementById('ratingInput');
        const starDescription = document.getElementById('starDescription');

        if (stars.length > 0 && ratingInput) {
            const descriptions = {
                1: 'Tệ hại (1/5)',
                2: 'Kém (2/5)',
                3: 'Trung bình (3/5)',
                4: 'Khá tốt (4/5)',
                5: 'Tuyệt vời! (5/5)'
            };

            stars.forEach(star => {
                star.addEventListener('click', function() {
                    const value = parseInt(this.getAttribute('data-value'));
                    ratingInput.value = value;
                    updateStars(value);
                });

                star.addEventListener('mouseenter', function() {
                    const value = parseInt(this.getAttribute('data-value'));
                    highlightStars(value);
                });

                star.addEventListener('mouseleave', function() {
                    const currentValue = parseInt(ratingInput.value);
                    updateStars(currentValue);
                });
            });

            function highlightStars(count) {
                stars.forEach(star => {
                    const val = parseInt(star.getAttribute('data-value'));
                    if (val <= count) {
                        star.classList.remove('bi-star');
                        star.classList.add('bi-star-fill');
                    } else {
                        star.classList.remove('bi-star-fill');
                        star.classList.add('bi-star');
                    }
                });
                starDescription.innerText = descriptions[count];
            }

            function updateStars(count) {
                highlightStars(count);
            }
        }

        // Show Toast Notifications if TempData has messages
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: '@Html.Raw(TempData["Success"])',
                showConfirmButton: false,
                timer: 4000,
                timerProgressBar: true
            });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'error',
                title: '@Html.Raw(TempData["Error"])',
                showConfirmButton: false,
                timer: 4000,
                timerProgressBar: true
            });
            </text>
        }
    });
</script>
