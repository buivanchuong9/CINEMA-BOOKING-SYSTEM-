<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - CineMax</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    
    <!-- Swiper.js CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    
    <!-- Flatpickr CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    
    <!-- AOS (Animate On Scroll) CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css">
    
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/typography-fix.css" asp-append-version="true"/>
</head>
<body style="background-color: #000;">
    
    <!-- TempData Notifications (SweetAlert2 Toast) -->
    @if (TempData["Success"] != null)
    {
        <span id="_toast_success" data-message="@TempData["Success"]" style="display:none;"></span>
    }
    @if (TempData["Error"] != null)
    {
        <span id="_toast_error" data-message="@TempData["Error"]" style="display:none;"></span>
    }
    @if (TempData["Warning"] != null)
    {
        <span id="_toast_warning" data-message="@TempData["Warning"]" style="display:none;"></span>
    }
    @if (TempData["Info"] != null)
    {
        <span id="_toast_info" data-message="@TempData["Info"]" style="display:none;"></span>
    }

    <!-- Main Content -->
    @RenderBody()

    <!-- Scripts -->
    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Swiper.js -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    
    <!-- Flatpickr -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    
    <!-- AOS (Animate On Scroll) -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Initialize AOS -->
    <script>
        AOS.init({
            duration: 800,
            once: true,
            offset: 100
        });

        // CineMax Toast Notification System
        const CineToast = {
            _showToast: function(type, message) {
                const bgMap = {
                    success: 'linear-gradient(135deg, #0d6e3f 0%, #198754 100%)',
                    error:   'linear-gradient(135deg, #7f0000 0%, #dc3545 100%)',
                    warning: 'linear-gradient(135deg, #7c5a00 0%, #ffc107 100%)',
                    info:    'linear-gradient(135deg, #0a3d6b 0%, #0dcaf0 100%)'
                };
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: type,
                    title: message,
                    showConfirmButton: false,
                    timer: 5000,
                    timerProgressBar: true,
                    showCloseButton: true,
                    customClass: {
                        popup: 'cinemax-toast-popup',
                        title: 'cinemax-toast-title',
                        timerProgressBar: 'cinemax-toast-progress'
                    },
                    background: bgMap[type] || bgMap.info,
                    color: '#ffffff',
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer);
                        toast.addEventListener('mouseleave', Swal.resumeTimer);
                    }
                });
            },
            success: function(msg) { this._showToast('success', msg); },
            error:   function(msg) { this._showToast('error',   msg); },
            warning: function(msg) { this._showToast('warning', msg); },
            info:    function(msg) { this._showToast('info',    msg); }
        };

        document.addEventListener('DOMContentLoaded', function() {
            var s = document.getElementById('_toast_success');
            var e = document.getElementById('_toast_error');
            var w = document.getElementById('_toast_warning');
            var i = document.getElementById('_toast_info');
            if (s) CineToast.success(s.getAttribute('data-message'));
            if (e) CineToast.error(e.getAttribute('data-message'));
            if (w) CineToast.warning(w.getAttribute('data-message'));
            if (i) CineToast.info(i.getAttribute('data-message'));
        });
    </script>
    <style>
        .cinemax-toast-popup {
            border-radius: 12px !important;
            box-shadow: 0 8px 32px rgba(0,0,0,0.45) !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
            padding: 14px 18px !important;
            min-width: 320px !important;
            backdrop-filter: blur(10px);
        }
        .cinemax-toast-title {
            font-size: 0.95rem !important;
            font-weight: 600 !important;
            text-align: left !important;
            line-height: 1.4 !important;
        }
        .cinemax-toast-progress {
            background: rgba(255,255,255,0.5) !important;
            height: 3px !important;
        }
        .swal2-close {
            color: rgba(255,255,255,0.8) !important;
        }
        .swal2-close:hover {
            color: #fff !important;
        }
    </style>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
