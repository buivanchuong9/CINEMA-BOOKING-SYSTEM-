@using BE.Application.Helpers
@model PaginatedList<BE.Core.Entities.Movies.Showtime>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Nhân Viên - Bán Vé";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-white">
            <i class="bi bi-ticket-perforated me-2 text-cinema-red"></i>
            Quầy Bán Vé & Thanh Toán
        </h2>
        <div class="d-flex gap-2">
            @if (ViewBag.AssignedCinemaId != null)
            {
                <a href="/Staff/Booking/SalesDashboard" class="btn btn-outline-warning rounded-pill px-4">
                    <i class="bi bi-bar-chart-line me-2"></i> Doanh Thu & Báo Cáo
                </a>
            }
            <a href="/Staff/Booking/ManageBookings" class="btn btn-outline-light rounded-pill px-4">
                <i class="bi bi-list-ul me-2"></i> Lịch Sử & Quản Lý Vé
            </a>
        </div>
    </div>

    <!-- Premium Filters Card for Showtimes -->
    <div class="glass-card p-4 mb-4 shadow">
        <form method="get" action="/Staff/Booking" id="showtimeFilterForm">
            <div class="row g-3">
                <!-- Cinema Filter -->
                <div class="col-md-4">
                    <label class="form-label text-muted small">Rạp Chiếu</label>
                    @if (ViewBag.AssignedCinemaId != null)
                    {
                        var assignedId = (int)ViewBag.AssignedCinemaId;
                        var cinemas = ViewBag.Cinemas as List<BE.Core.Entities.CinemaInfrastructure.Cinema>;
                        var assignedCinema = cinemas?.FirstOrDefault(c => c.Id == assignedId);
                        <select name="cinemaId_disabled" class="form-select bg-dark text-white border-secondary" disabled>
                            <option value="@assignedId">@(assignedCinema?.Name ?? "Rạp của bạn")</option>
                        </select>
                        <input type="hidden" name="cinemaId" value="@assignedId" />
                    }
                    else
                    {
                        <select name="cinemaId" class="form-select bg-dark text-white border-secondary" onchange="this.form.submit()">
                            <option value="">-- Tất cả rạp --</option>
                            @foreach (var c in ViewBag.Cinemas as List<BE.Core.Entities.CinemaInfrastructure.Cinema>)
                            {
                                <option value="@c.Id" selected="@(ViewBag.CinemaId == c.Id ? "selected" : null)">@c.Name</option>
                            }
                        </select>
                    }
                </div>

                <!-- Movie Filter -->
                <div class="col-md-4">
                    <label class="form-label text-muted small">Phim</label>
                    <select name="movieId" class="form-select bg-dark text-white border-secondary" onchange="this.form.submit()">
                        <option value="">-- Tất cả phim --</option>
                        @foreach (var m in ViewBag.Movies as List<BE.Core.Entities.Movies.Movie>)
                        {
                            <option value="@m.Id" selected="@(ViewBag.MovieId == m.Id ? "selected" : null)">@m.Title</option>
                        }
                    </select>
                </div>

                <!-- Date Filter -->
                <div class="col-md-2">
                    <label class="form-label text-muted small">Ngày Chiếu</label>
                    <input type="date" name="date" value="@ViewBag.Date" class="form-control bg-dark text-white border-secondary" onchange="this.form.submit()">
                </div>

                <!-- Clear filters button -->
                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" class="btn btn-outline-light w-100" onclick="clearShowtimeFilters()">
                        <i class="bi bi-x-circle me-1"></i> Xóa Bộ Lọc
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Showtimes Table -->
    <div class="glass-card p-4 shadow">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Phim</th>
                        <th>Rạp & Phòng</th>
                        <th>Thời Gian</th>
                        <th>Giá Cơ Bản</th>
                        <th>Trạng Thế</th>
                        <th class="text-center" style="width: 150px;">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                Không tìm thấy lịch chiếu nào phù hợp!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@item.Movie?.PosterUrl" alt="" style="width: 50px; height: 75px; object-fit: cover;" class="rounded me-3">
                                        <div>
                                            <div class="fw-bold text-white">@item.Movie?.Title</div>
                                            <small class="text-muted">@item.Movie?.Duration Phút</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-popcorn-gold">@item.Room?.Cinema?.Name</div>
                                    <small class="text-muted">@item.Room?.Name</small>
                                </td>
                                <td>
                                    <div class="fw-bold text-white">@item.StartTime.ToString("HH:mm")</div>
                                    <small class="text-muted">@item.StartTime.ToString("dd/MM/yyyy")</small>
                                </td>
                                <td class="fw-bold text-cinema-red">@item.BasePrice.ToString("N0") ₫</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Đang Mở</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Đã Đóng</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="/Staff/Booking/SelectSeats?showtimeId=@item.Id" class="btn btn-cinema-red btn-sm rounded-pill px-4 fw-bold">
                                        <i class="bi bi-cart-plus me-1"></i> Bán Vé
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Server-Side Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4">
                <nav>
                    <ul class="pagination">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" 
                               href="/Staff/Booking?cinemaId=@ViewBag.CinemaId&movieId=@ViewBag.MovieId&date=@ViewBag.Date&pageNumber=@(Model.PageIndex - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link @(i == Model.PageIndex ? "bg-cinema-red border-cinema-red" : "bg-dark border-secondary text-white")" 
                                   href="/Staff/Booking?cinemaId=@ViewBag.CinemaId&movieId=@ViewBag.MovieId&date=@ViewBag.Date&pageNumber=@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" 
                               href="/Staff/Booking?cinemaId=@ViewBag.CinemaId&movieId=@ViewBag.MovieId&date=@ViewBag.Date&pageNumber=@(Model.PageIndex + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function clearShowtimeFilters() {
            document.querySelectorAll('#showtimeFilterForm select').forEach(select => {
                select.value = "";
            });
            document.querySelector('#showtimeFilterForm input[type="date"]').value = "";
            document.getElementById('showtimeFilterForm').submit();
        }
    </script>
}
