@using BE.Application.Helpers
@model PaginatedList<BE.Core.Entities.Bookings.Booking>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản Lý Đơn Hàng - Nhân Viên";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Lịch Sử & Quản Lý Đơn Hàng</h2>
            <p class="text-muted">Trang @Model.PageIndex / @Model.TotalPages</p>
        </div>
        <a asp-action="Index" class="btn btn-cinema-red rounded-pill">Bán Vé Mới</a>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Ngày Đặt</th>
                        <th>Khách Hàng</th>
                        <th>Phim</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th>Thanh Toán</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td>#@b.Id</td>
                            <td>@b.BookingDate.ToString("dd/MM HH:mm")</td>
                            <td>
                                <div>@b.User?.FullName</div>
                                <small class="text-muted">@b.User?.Email</small>
                            </td>
                            <td>@b.Notes</td> @* Note: I reused Notes for Movie Title in Controller *@
                            <td>@b.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                @if (b.Status == BE.Core.Enums.BookingStatus.Paid)
                                {
                                    <span class="badge bg-success">Đã Thanh Toán</span>
                                }
                                else if (b.Status == BE.Core.Enums.BookingStatus.Pending)
                                {
                                    <span class="badge bg-warning">Chờ Thanh Toán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@b.Status</span>
                                }
                            </td>
                            <td>@b.PaymentMethod</td>
                            <td>
                                <div class="btn-group">
                                    <a asp-action="PrintTicket" asp-route-id="@b.Id" class="btn btn-sm btn-outline-info">In Vé</a>
                                    @if (b.Status == BE.Core.Enums.BookingStatus.Pending)
                                    {
                                        <form asp-action="ConfirmCashPayment" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">Xác Nhận Tiền Mặt</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-center mt-4">
            <nav>
                <ul class="pagination">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link bg-dark border-secondary text-white" asp-action="ManageBookings" asp-route-pageNumber="@(Model.PageIndex - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link @(i == Model.PageIndex ? "bg-cinema-red border-cinema-red" : "bg-dark border-secondary text-white")" 
                               asp-action="ManageBookings" asp-route-pageNumber="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link bg-dark border-secondary text-white" asp-action="ManageBookings" asp-route-pageNumber="@(Model.PageIndex + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
