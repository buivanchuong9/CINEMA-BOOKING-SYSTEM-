@model BE.Core.Entities.Bookings.Booking
@{
    Layout = null; // No layout for printable ticket
    var showtime = ViewBag.Showtime as BE.Core.Entities.Movies.Showtime;
}
<!DOCTYPE html>
<html>
<head>
    <title>In Vé - CineMax</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f0f2f5; }
        .ticket-container { max-width: 400px; margin: 30px auto; background: white; padding: 20px; border: 1px dashed #ccc; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        .ticket-header { text-align: center; border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 15px; }
        .ticket-logo { font-weight: bold; font-size: 24px; color: #e11d48; }
        .ticket-info div { margin-bottom: 8px; font-size: 14px; }
        .ticket-info label { color: #666; width: 100px; display: inline-block; }
        .ticket-info strong { color: #333; }
        .qr-placeholder { background: #eee; height: 150px; display: flex; align-items: center; justify-content: center; margin: 20px 0; border: 1px solid #ddd; }
        .ticket-footer { text-align: center; font-size: 12px; color: #999; margin-top: 20px; border-top: 1px solid #eee; padding-top: 10px; }
        @@media print {
            body { background: white; }
            .no-print { display: none; }
            .ticket-container { box-shadow: none; margin: 0 auto; border: 1px solid #000; }
        }
    </style>
</head>
<body>
    <div class="no-print text-center mt-3">
        <button onclick="window.print()" class="btn btn-primary">In Ngay (Print)</button>
        <a href="/Staff/Booking" class="btn btn-secondary">Quay Lại</a>
    </div>

    <div class="ticket-container">
        <div class="ticket-header">
            <div class="ticket-logo">CINEMAX</div>
            <div class="small text-muted">Hóa Đơn Xem Phim</div>
        </div>

        <div class="ticket-info">
            <div><label>Mã Đơn:</label> <strong>#@Model.Id</strong></div>
            <div><label>Phim:</label> <strong>@showtime?.Movie?.Title</strong></div>
            <div><label>Thời Gian:</label> <strong>@showtime?.StartTime.ToString("dd/MM/yyyy HH:mm")</strong></div>
            <div><label>Rạp:</label> <strong>@showtime?.Room?.Cinema?.Name</strong></div>
            <div><label>Phòng:</label> <strong>@showtime?.Room?.Name</strong></div>
            <div><label>Ghế:</label> <strong style="font-size: 18px; color: #e11d48;">@ViewBag.Seats</strong></div>
            <hr>
            <div><label>Đồ Ăn:</label> <span>@ViewBag.Foods</span></div>
            <div><label>Tổng Tiền:</label> <strong>@Model.TotalAmount.ToString("N0") ₫</strong></div>
            <div><label>Khách:</label> <span>@Model.User?.FullName</span></div>
            <div><label>Ngày Xuất:</label> <span>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span></div>
        </div>

        <div class="qr-placeholder">
            <div class="text-center">
                <i class="bi bi-qr-code" style="font-size: 40px;"></i><br>
                <small>@Model.TransactionId</small>
            </div>
        </div>

        <div class="ticket-footer">
            Cảm ơn quý khách đã sử dụng dịch vụ tại CineMax!<br>
            Vui lòng giữ vé để đối soát tại cổng soát vé.
        </div>
    </div>
</body>
</html>
