<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - CineMax Admin</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/typography-fix.css" asp-append-version="true"/>
    
    <style>
        body {
            background: #0a0a0a;
            color: #fff;
            overflow: hidden;
        }

        .admin-wrapper {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }
        
        .admin-sidebar {
            width: 260px;
            flex-shrink: 0;
            height: 100vh;
            background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1e 100%);
            border-right: 1px solid #333;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        
        .admin-nav-link {
            color: #aaa;
            padding: 12px 20px;
            display: block;
            text-decoration: none;
            transition: all 0.3s;
            border-left: 3px solid transparent;
        }
        
        .admin-nav-link:hover,
        .admin-nav-link.active {
            color: #fff;
            background: rgba(220, 38, 38, 0.1);
            border-left-color: #dc2626;
        }
        
        .admin-content {
            flex-grow: 1;
            height: 100vh;
            overflow-y: auto;
            background: #0a0a0a;
            display: flex;
            flex-direction: column;
        }

        .admin-top-bar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: #111 !important;
            border-bottom: 1px solid #333 !important;
        }
    </style>
</head>
<body>
    <div class="admin-wrapper">
        <!-- Admin Sidebar -->
        <div class="admin-sidebar">
            <!-- Logo -->
            <div class="p-4 border-bottom border-secondary">
                <a href="/" class="text-decoration-none">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-camera-reels-fill fs-3 me-2 text-danger"></i>
                        <div>
                            <h5 class="mb-0 text-white fw-bold">CineMax</h5>
                            <small class="text-muted">Admin Panel</small>
                        </div>
                    </div>
                </a>
            </div>
            
            <!-- Navigation -->
            <nav class="mt-3 flex-grow-1">
                <a href="/Admin/Dashboard" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
                <a href="/Admin/Movies" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Movies" ? "active" : "")">
                    <i class="bi bi-film me-2"></i> Quản Lý Phim
                </a>
                <a href="/Admin/Showtimes" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Showtimes" ? "active" : "")">
                    <i class="bi bi-calendar-event me-2"></i> Lịch Chiếu
                </a>
                <a href="/Admin/Bookings" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bookings" ? "active" : "")">
                    <i class="bi bi-ticket-detailed me-2"></i> Quản Lý Vé Đã Đặt
                </a>
                <a href="/Admin/Cinemas" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cinemas" ? "active" : "")">
                    <i class="bi bi-building me-2"></i> Rạp Chiếu
                </a>
                <a href="/Admin/Rooms" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rooms" ? "active" : "")">
                    <i class="bi bi-door-open me-2"></i> Phòng Chiếu
                </a>
                <a href="/Admin/Genres" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Genres" ? "active" : "")">
                    <i class="bi bi-tags me-2"></i> Thể Loại
                </a>
                <a href="/Admin/Foods" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Foods" ? "active" : "")">
                    <i class="bi bi-cup-straw me-2"></i> Đồ Ăn
                </a>
                <hr class="border-secondary mx-3">
                <small class="text-muted px-3 text-uppercase" style="font-size: 0.75rem;">Người Dùng</small>
                
                <a href="/Admin/Users?role=Customer" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" && Context.Request.Query["role"] == "Customer" ? "active" : "")">
                    <i class="bi bi-people me-2"></i> Người Dùng
                </a>
                <a href="/Admin/Users?role=Staff" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" && Context.Request.Query["role"] == "Staff" ? "active" : "")">
                    <i class="bi bi-person-badge me-2"></i> Nhân Viên Bán Hàng
                </a>
                <a href="/Admin/Users?role=Admin" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" && Context.Request.Query["role"] == "Admin" ? "active" : "")">
                    <i class="bi bi-shield-lock me-2"></i> Quản Trị Viên
                </a>
                
                <form method="post" action="/Account/Logout" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="admin-nav-link w-100 text-start border-0 bg-transparent">
                        <i class="bi bi-box-arrow-right me-2"></i> Đăng Xuất
                    </button>
                </form>
            </nav>
        </div>
        
        <!-- Main Content -->
        <div class="admin-content">
            <!-- Top Bar -->
            <div class="admin-top-bar px-4 py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-white">@ViewData["Title"]</h5>
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-muted">
                            <i class="bi bi-person-circle me-1"></i>
                            @User.Identity?.Name
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="p-0">
                <!-- TempData Notifications (SweetAlert2 Toast) -->
                @if (TempData["Success"] != null)
                {
                    <span id="_toast_success" data-message="@TempData["Success"]" style="display:none;"></span>
                }
                @if (TempData["Error"] != null)
                {
                    <span id="_toast_error" data-message="@TempData["Error"]" style="display:none;"></span>
                }
                @if (TempData["Warning"] != null)
                {
                    <span id="_toast_warning" data-message="@TempData["Warning"]" style="display:none;"></span>
                }
                @if (TempData["Info"] != null)
                {
                    <span id="_toast_info" data-message="@TempData["Info"]" style="display:none;"></span>
                }
                
                <!-- Page Content -->
                <main>
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>


    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // CineMax Admin Toast Notification System
        const CineToast = {
            _showToast: function(type, message) {
                const bgMap = {
                    success: 'linear-gradient(135deg, #0d6e3f 0%, #198754 100%)',
                    error:   'linear-gradient(135deg, #7f0000 0%, #dc3545 100%)',
                    warning: 'linear-gradient(135deg, #7c5a00 0%, #ffc107 100%)',
                    info:    'linear-gradient(135deg, #0a3d6b 0%, #0dcaf0 100%)'
                };
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: type,
                    title: message,
                    showConfirmButton: false,
                    timer: 5000,
                    timerProgressBar: true,
                    showCloseButton: true,
                    customClass: {
                        popup: 'cinemax-toast-popup',
                        title: 'cinemax-toast-title',
                        timerProgressBar: 'cinemax-toast-progress'
                    },
                    background: bgMap[type] || bgMap.info,
                    color: '#ffffff',
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer);
                        toast.addEventListener('mouseleave', Swal.resumeTimer);
                    }
                });
            },
            success: function(msg) { this._showToast('success', msg); },
            error:   function(msg) { this._showToast('error',   msg); },
            warning: function(msg) { this._showToast('warning', msg); },
            info:    function(msg) { this._showToast('info',    msg); }
        };

        document.addEventListener('DOMContentLoaded', function() {
            var s = document.getElementById('_toast_success');
            var e = document.getElementById('_toast_error');
            var w = document.getElementById('_toast_warning');
            var i = document.getElementById('_toast_info');
            if (s) CineToast.success(s.getAttribute('data-message'));
            if (e) CineToast.error(e.getAttribute('data-message'));
            if (w) CineToast.warning(w.getAttribute('data-message'));
            if (i) CineToast.info(i.getAttribute('data-message'));
        });
    </script>
    <style>
        .cinemax-toast-popup {
            border-radius: 12px !important;
            box-shadow: 0 8px 32px rgba(0,0,0,0.45) !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
            padding: 14px 18px !important;
            min-width: 320px !important;
            backdrop-filter: blur(10px);
        }
        .cinemax-toast-title {
            font-size: 0.95rem !important;
            font-weight: 600 !important;
            text-align: left !important;
            line-height: 1.4 !important;
        }
        .cinemax-toast-progress {
            background: rgba(255,255,255,0.5) !important;
            height: 3px !important;
        }
        .swal2-close {
            color: rgba(255,255,255,0.8) !important;
        }
        .swal2-close:hover {
            color: #fff !important;
        }
    </style>

    @if (IsSectionDefined("Scripts"))
    {
        @RenderSection("Scripts", required: false)
    }
</body>
</html>
