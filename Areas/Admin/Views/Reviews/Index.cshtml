@using BE.Application.Helpers
@using System.Text.Encodings.Web
@model PaginatedList<BE.Core.Entities.Movies.MovieReview>
@{
    ViewData["Title"] = "Quản Lý Đánh Giá - Admin";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">
                <i class="bi bi-chat-left-text me-2 text-cinema-red"></i>
                Quản Lý Đánh Giá
            </h2>
            <p class="text-muted mb-0">Trang @Model.PageIndex / @Model.TotalPages</p>
        </div>
    </div>

    <!-- Search Bar -->
    <div class="glass-card p-3 mb-4">
        <form method="get" action="/Admin/Reviews" class="d-flex gap-2">
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control bg-dark text-white border-secondary" placeholder="Tìm kiếm theo tên phim, tên khách hàng, nội dung đánh giá...">
                <button class="btn btn-cinema-red" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                {
                    <a href="/Admin/Reviews" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Xóa
                    </a>
                }
            </div>
        </form>
    </div>

    <div class="glass-card p-4">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-square-text display-1 text-muted mb-3"></i>
                <h4 class="text-muted">Chưa có đánh giá nào</h4>
                <p class="text-muted">Đánh giá từ khách hàng sẽ xuất hiện tại đây.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 18%">Phim</th>
                            <th style="width: 15%">Khách Hàng</th>
                            <th style="width: 10%">Số Sao</th>
                            <th style="width: 25%">Đánh Giá</th>
                            <th style="width: 22%">Phản Hồi</th>
                            <th style="width: 10%">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var review in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@(review.Movie?.Title ?? "Phim đã xóa")</strong>
                                </td>
                                <td>
                                    <div>@review.User?.FullName</div>
                                    <small class="text-muted">@review.User?.Email</small>
                                </td>
                                <td>
                                    <span class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="bi bi-star-fill me-1"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star me-1"></i>
                                            }
                                        }
                                    </span>
                                </td>
                                <td>
                                    <div class="comment-text">@review.Comment</div>
                                    <small class="text-muted"><i class="bi bi-clock me-1"></i>@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(review.Response))
                                    {
                                        <div class="response-text text-popcorn-gold border-start border-warning ps-2 py-1">
                                            @review.Response
                                        </div>
                                        <small class="text-muted">
                                            <i class="bi bi-person-check me-1"></i>@review.RespondedBy • @review.RespondedAt?.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><em>Chưa phản hồi</em></span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <button type="button" class="btn btn-sm btn-outline-warning" 
                                                onclick="openReplyModal(@review.Id, '@Html.Raw(JavaScriptEncoder.Default.Encode(review.Comment))', '@Html.Raw(JavaScriptEncoder.Default.Encode(review.Response ?? ""))')">
                                            <i class="bi bi-reply-fill"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete(@review.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="d-flex justify-content-center mt-4">
                <nav>
                    <ul class="pagination">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" href="/Admin/Reviews?pageNumber=@(Model.PageIndex - 1)&search=@ViewBag.Search">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link @(i == Model.PageIndex ? "bg-cinema-red border-cinema-red" : "bg-dark border-secondary text-white")" 
                                   href="/Admin/Reviews?pageNumber=@i&search=@ViewBag.Search">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" href="/Admin/Reviews?pageNumber=@(Model.PageIndex + 1)&search=@ViewBag.Search">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- Reply Modal -->
<div class="modal fade" id="replyModal" tabindex="-1" aria-labelledby="replyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-secondary">
            <form id="replyForm" method="post" action="/Admin/Reviews/Reply">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="replyReviewId" />
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="replyModalLabel">
                        <i class="bi bi-reply-fill text-warning me-2"></i>Phản Hồi Đánh Giá
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted">Đánh giá của khách hàng:</label>
                        <blockquote class="blockquote bg-dark-subtle p-3 rounded border-start border-danger" id="customerComment" style="font-size: 0.95rem;">
                        </blockquote>
                    </div>
                    <div class="mb-3">
                        <label for="responseText" class="form-label required">Nội dung phản hồi:</label>
                        <textarea class="form-control bg-dark text-white border-secondary" id="responseText" name="responseText" rows="4" required placeholder="Nhập câu trả lời của bạn..."></textarea>
                    </div>
                </div>
                <div class="modal-header border-secondary d-flex justify-content-end gap-2 p-3">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-cinema-red">Gửi Phản Hồi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Form -->
<form id="deleteForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        var replyModal;
        document.addEventListener('DOMContentLoaded', function() {
            replyModal = new bootstrap.Modal(document.getElementById('replyModal'));
        });

        function openReplyModal(id, comment, currentResponse) {
            document.getElementById('replyReviewId').value = id;
            document.getElementById('customerComment').innerText = comment;
            document.getElementById('responseText').value = currentResponse;
            replyModal.show();
        }

        function confirmDelete(id) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: 'Bạn có chắc chắn muốn xóa đánh giá này? Hành động này sẽ thay đổi điểm trung bình của phim.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm');
                    form.action = `/Admin/Reviews/Delete/${id}`;
                    form.submit();
                }
            });
        }
    </script>
}

<style>
    .comment-text, .response-text {
        font-size: 0.95rem;
        word-break: break-word;
        white-space: pre-line;
    }
    .text-popcorn-gold {
        color: #f59e0b;
    }
    .bg-dark-subtle {
        background-color: rgba(255, 255, 255, 0.05) !important;
    }
    .required::after {
        content: " *";
        color: #dc2626;
    }
</style>
