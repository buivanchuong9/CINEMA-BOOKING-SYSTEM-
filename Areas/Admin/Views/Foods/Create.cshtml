@model BE.Core.Entities.Concessions.Food
@{
    ViewData["Title"] = "Thêm Đồ Ăn - Admin";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-plus-circle me-2 text-cinema-red"></i>
            Thêm Đồ Ăn & Nước Mới
        </h2>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-card p-4">
                <form method="post" asp-action="Create">
                    @Html.AntiForgeryToken()
                    
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label required">Tên Món</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Combo 1 - Bắp + Nước" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label">Mô Tả</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="1 Bắp Rang Bơ (L) + 1 Pepsi (L)"></textarea>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label required">Giá (VNĐ)</label>
                            <input asp-for="Price" type="number" class="form-control" placeholder="80000" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DisplayOrder" class="form-label">Thứ Tự Hiển Thị</label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" value="1" />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="ImageUrl" class="form-label">Hình Ảnh</label>
                            <div class="input-group mb-2">
                                <input asp-for="ImageUrl" class="form-control" placeholder="https://... hoặc upload ảnh bên dưới" id="foodImageUrlInput" />
                                <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('foodFileInput').click()">
                                    <i class="bi bi-cloud-arrow-up me-1"></i> Upload
                                </button>
                            </div>
                            <input type="file" id="foodFileInput" accept="image/*" class="d-none" onchange="uploadImage(this, 'foodImageUrlInput', 'foodImagePreview', 'foods')" />
                            <div id="foodImagePreview" class="upload-preview mt-2"></div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Loại</label>
                            <div class="form-check">
                                <input asp-for="IsCombo" class="form-check-input" />
                                <label asp-for="IsCombo" class="form-check-label">
                                    Đây là Combo
                                </label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Trạng Thái</label>
                            <div class="form-check">
                                <input asp-for="IsAvailable" class="form-check-input" checked />
                                <label asp-for="IsAvailable" class="form-check-label">
                                    Còn Hàng
                                </label>
                            </div>
                        </div>

                        <div class="col-md-12 mt-4">
                            <button type="submit" class="btn btn-cinema-red btn-lg">
                                <i class="bi bi-check-circle me-2"></i>
                                Lưu Món
                            </button>
                            <a href="/Admin/Foods" class="btn btn-outline-light btn-lg ms-2">
                                <i class="bi bi-x-circle me-2"></i>
                                Hủy
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function uploadImage(fileInput, urlInputId, previewId, folder) {
            var file = fileInput.files[0];
            if (!file) return;

            var maxSize = 5 * 1024 * 1024;
            if (file.size > maxSize) {
                alert('File ảnh không được vượt quá 5MB.');
                fileInput.value = '';
                return;
            }

            var preview = document.getElementById(previewId);
            preview.innerHTML = '<div class="upload-progress"><div class="upload-progress-bar" id="prog_' + urlInputId + '"></div></div><small class="text-muted mt-1 d-block">Đang upload...</small>';

            var formData = new FormData();
            formData.append('file', file);

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/Admin/Upload/Image?folder=' + encodeURIComponent(folder), true);

            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) formData.append('__RequestVerificationToken', token.value);

            xhr.upload.onprogress = function(e) {
                if (e.lengthComputable) {
                    var pct = (e.loaded / e.total) * 100;
                    var bar = document.getElementById('prog_' + urlInputId);
                    if (bar) bar.style.width = pct + '%';
                }
            };

            xhr.onload = function() {
                if (xhr.status === 200) {
                    var result = JSON.parse(xhr.responseText);
                    if (result.success) {
                        document.getElementById(urlInputId).value = result.url;
                        preview.innerHTML = '<img src="' + result.url + '" alt="Preview" /><br><small class="text-success mt-1 d-block"><i class="bi bi-check-circle me-1"></i>Upload thành công!</small>';
                    } else {
                        preview.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle me-1"></i>' + result.message + '</small>';
                    }
                } else {
                    preview.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle me-1"></i>Lỗi upload.</small>';
                }
            };

            xhr.onerror = function() {
                preview.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle me-1"></i>Lỗi kết nối.</small>';
            };

            xhr.send(formData);
            fileInput.value = '';
        }
    </script>
}

<style>
    .required::after {
        content: " *";
        color: #dc2626;
    }
    .upload-preview img {
        max-height: 120px;
        border-radius: 8px;
        border: 2px solid #333;
        object-fit: cover;
    }
    .upload-progress {
        height: 4px;
        background: #333;
        border-radius: 2px;
        overflow: hidden;
        margin-top: 6px;
    }
    .upload-progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #e50914, #ff6b6b);
        width: 0%;
        transition: width 0.3s;
    }
</style>
