@using BE.Application.Helpers
@model PaginatedList<BE.Core.Entities.Concessions.Food>
@{
    ViewData["Title"] = "Quản Lý Đồ Ăn - Admin";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">
                <i class="bi bi-cup-straw me-2 text-cinema-red"></i>
                Quản Lý Đồ Ăn & Nước
            </h2>
            <p class="text-muted mb-0">Trang @Model.PageIndex / @Model.TotalPages</p>
        </div>
        <a href="/Admin/Foods/Create" class="btn btn-cinema-red">
            <i class="bi bi-plus-circle me-2"></i>
            Thêm Món Mới
        </a>
    </div>

    <!-- Search Bar -->
    <div class="glass-card p-3 mb-4">
        <form method="get" action="/Admin/Foods" class="d-flex gap-2">
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control bg-dark text-white border-secondary" placeholder="Tìm kiếm theo tên món ăn, mô tả...">
                <button class="btn btn-cinema-red" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                {
                    <a href="/Admin/Foods" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Xóa
                    </a>
                }
            </div>
        </form>
    </div>

    <div class="glass-card p-4">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-cup-straw display-1 text-muted mb-3"></i>
                <h4 class="text-muted">Chưa có món nào</h4>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hình</th>
                            <th>Tên Món</th>
                            <th>Giá</th>
                            <th>Loại</th>
                            <th>Trạng Thái</th>
                            <th>Thứ Tự</th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var food in Model)
                        {
                            <tr>
                                <td>@food.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(food.ImageUrl))
                                    {
                                        <img src="@food.ImageUrl" alt="@food.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary" style="width: 60px; height: 60px; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-cup-straw text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <strong>@food.Name</strong>
                                    @if (!string.IsNullOrEmpty(food.Description))
                                    {
                                        <br><small class="text-muted">@food.Description</small>
                                    }
                                </td>
                                <td>
                                    <strong class="text-cinema-red">@food.Price.ToString("N0")đ</strong>
                                </td>
                                <td>
                                    @if (food.IsCombo)
                                    {
                                        <span class="badge bg-popcorn-gold">Combo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đơn Lẻ</span>
                                    }
                                </td>
                                <td>
                                    @if (food.IsAvailable)
                                    {
                                        <span class="badge bg-success">Còn Hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết Hàng</span>
                                    }
                                </td>
                                <td>@food.DisplayOrder</td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/Admin/Foods/Edit/@food.Id" class="btn btn-sm btn-outline-light">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete(@food.Id, '@food.Name')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="d-flex justify-content-center mt-4">
                <nav>
                    <ul class="pagination">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" href="/Admin/Foods?pageNumber=@(Model.PageIndex - 1)&search=@ViewBag.Search">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link @(i == Model.PageIndex ? "bg-cinema-red border-cinema-red" : "bg-dark border-secondary text-white")" 
                                   href="/Admin/Foods?pageNumber=@i&search=@ViewBag.Search">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link bg-dark border-secondary text-white" href="/Admin/Foods?pageNumber=@(Model.PageIndex + 1)&search=@ViewBag.Search">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<form id="deleteForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: `Bạn có chắc muốn xóa món "${name}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm');
                    form.action = `/Admin/Foods/Delete/${id}`;
                    form.submit();
                }
            });
        }
    </script>
}

<style>
    .bg-popcorn-gold {
        background: linear-gradient(135deg, #f59e0b, #d97706) !important;
    }
</style>
