@model BE.Core.Entities.Movies.Movie
@{
    ViewData["Title"] = "Chỉnh Sửa Phim - Admin";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-pencil me-2 text-cinema-red"></i>
            Chỉnh Sửa Phim: @Model.Title
        </h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Admin/Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/Admin/Movies">Phim</a></li>
                <li class="breadcrumb-item active">Chỉnh sửa #@Model.Id</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="glass-card p-4">
                <form method="post" asp-action="Edit" asp-route-id="@Model.Id" id="editMovieForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label required">Tên Phim</label>
                            <input asp-for="Title" class="form-control form-control-lg" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Duration" class="form-label required">Thời Lượng (phút)</label>
                            <input asp-for="Duration" type="number" class="form-control" />
                            <span asp-validation-for="Duration" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReleaseDate" class="form-label required">Ngày Khởi Chiếu</label>
                            <input asp-for="ReleaseDate" type="date" class="form-control" />
                            <span asp-validation-for="ReleaseDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label">Trạng Thái</label>
                            <select asp-for="Status" class="form-select">
                                <option value="0">Đang Chiếu</option>
                                <option value="1">Sắp Chiếu</option>
                                <option value="2">Đã Kết Thúc</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AgeRating" class="form-label">Giới Hạn Tuổi</label>
                            <select asp-for="AgeRating" class="form-select">
                                <option value="">Chọn...</option>
                                <option value="P">P - Phổ biến</option>
                                <option value="C13">C13 - Trên 13 tuổi</option>
                                <option value="C16">C16 - Trên 16 tuổi</option>
                                <option value="C18">C18 - Trên 18 tuổi</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label">Mô Tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Director" class="form-label">Đạo Diễn</label>
                            <input asp-for="Director" class="form-control" />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Cast" class="form-label">Diễn Viên</label>
                            <input asp-for="Cast" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PosterUrl" class="form-label">Poster Phim</label>
                            <div class="input-group mb-2">
                                <input asp-for="PosterUrl" class="form-control" placeholder="https://... hoặc upload ảnh bên dưới" id="posterUrlInput" />
                                <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('posterFileInput').click()">
                                    <i class="bi bi-cloud-arrow-up me-1"></i> Upload
                                </button>
                            </div>
                            <input type="file" id="posterFileInput" accept="image/*" class="d-none" onchange="uploadImage(this, 'posterUrlInput', 'posterPreview', 'movies')" />
                            <div id="posterPreview" class="upload-preview mt-2"></div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TrailerUrl" class="form-label">URL Trailer</label>
                            <input asp-for="TrailerUrl" class="form-control" />
                        </div>

                        <div class="col-md-12 mt-4">
                            <button type="submit" class="btn btn-cinema-red btn-lg">
                                <i class="bi bi-check-circle me-2"></i>
                                Cập Nhật
                            </button>
                            <a href="/Admin/Movies" class="btn btn-outline-light btn-lg ms-2">
                                <i class="bi bi-x-circle me-2"></i>
                                Hủy
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-4">
            <div class="glass-card p-4 mb-3">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-image me-2 text-cinema-red"></i>
                    Preview Poster
                </h5>
                @if (!string.IsNullOrEmpty(Model.PosterUrl))
                {
                    <img src="@Model.PosterUrl" alt="@Model.Title" class="img-fluid rounded" />
                }
                else
                {
                    <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="height: 300px;">
                        <i class="bi bi-film display-4 text-muted"></i>
                    </div>
                }
            </div>

            <div class="glass-card p-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-info-circle me-2 text-cinema-red"></i>
                    Thông Tin
                </h5>
                <p class="small mb-2">
                    <strong>ID:</strong> @Model.Id
                </p>
                <p class="small mb-0">
                    <strong>Tạo lúc:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Configure validation to be less strict
            $.validator.setDefaults({
                ignore: [],
                errorClass: 'is-invalid',
                validClass: 'is-valid',
                errorElement: 'span',
                errorPlacement: function(error, element) {
                    error.addClass('invalid-feedback');
                    element.closest('.col-md-12, .col-md-6').find('.text-danger').html(error);
                },
                highlight: function(element) {
                    $(element).addClass('is-invalid').removeClass('is-valid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid').addClass('is-valid');
                }
            });

            // Ensure form validation is properly initialized
            var form = $('#editMovieForm');
            if (form.length > 0) {
                form.removeData('validator');
                form.removeData('unobtrusiveValidation');
                $.validator.unobtrusive.parse(form);
            }

            // Debug: Log validation state on form submit
            form.on('submit', function(e) {
                var isValid = $(this).valid();
                console.log('Form validation state:', isValid);
                if (!isValid) {
                    console.log('Validation errors:', $(this).validate().errorList);
                }
            });
        });
    </script>
}

<style>
    .required::after {
        content: " *";
        color: #dc2626;
    }
    .upload-preview img { max-height: 120px; border-radius: 8px; border: 2px solid #333; object-fit: cover; }
    .upload-progress { height: 4px; background: #333; border-radius: 2px; overflow: hidden; margin-top: 6px; }
    .upload-progress-bar { height: 100%; background: linear-gradient(90deg, #e50914, #ff6b6b); width: 0%; transition: width 0.3s; }
</style>

<script>
    function uploadImage(fileInput, urlInputId, previewId, folder) {
        var file = fileInput.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) {
            Swal.fire({ icon: 'error', title: 'File quá lớn', text: 'File ảnh không được vượt quá 5MB.', background: '#1a1a2e', color: '#fff' });
            fileInput.value = ''; return;
        }
        var preview = document.getElementById(previewId);
        preview.innerHTML = '<div class="upload-progress"><div class="upload-progress-bar" id="prog_' + urlInputId + '"></div></div><small class="text-muted mt-1 d-block">Đang upload...</small>';
        var formData = new FormData();
        formData.append('file', file);
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/Admin/Upload/Image?folder=' + encodeURIComponent(folder), true);
        var token = document.querySelector('input[name="__RequestVerificationToken"]');
        if (token) formData.append('__RequestVerificationToken', token.value);
        xhr.upload.onprogress = function(e) { if (e.lengthComputable) { var bar = document.getElementById('prog_' + urlInputId); if (bar) bar.style.width = (e.loaded / e.total * 100) + '%'; } };
        xhr.onload = function() {
            if (xhr.status === 200) {
                var result = JSON.parse(xhr.responseText);
                if (result.success) { document.getElementById(urlInputId).value = result.url; preview.innerHTML = '<img src="' + result.url + '" alt="Preview" /><br><small class="text-success mt-1 d-block"><i class="bi bi-check-circle me-1"></i>Upload thành công!</small>'; }
                else { preview.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle me-1"></i>' + result.message + '</small>'; }
            } else { preview.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle me-1"></i>Lỗi upload.</small>'; }
        };
        xhr.onerror = function() { preview.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle me-1"></i>Lỗi kết nối.</small>'; };
        xhr.send(formData);
        fileInput.value = '';
    }
</script>
